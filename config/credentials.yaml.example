# Copy this file to credentials.yaml and fill in real values.
# credentials.yaml is git-ignored — never commit real keys.
# After editing, run:    chmod 600 config/credentials.yaml

alpaca:
  # Active mode. Flip to `false` (and confirm via the YES-I-UNDERSTAND prompt)
  # to trade live; the corresponding key block below is then used. Paper and
  # live have separate API keys on Alpaca — keep both populated so you can
  # switch without overwriting the other.
  paper: true

  paper_keys:
    api_key:    "your_paper_api_key_PK..."
    secret_key: "your_paper_secret_key"

  live_keys:
    api_key:    "your_live_api_key_AK..."
    secret_key: "your_live_secret_key"

# Legacy single-account format (still supported for backward compatibility):
# alpaca:
#   paper:      true
#   api_key:    "..."
#   secret_key: "..."

alerts:
  smtp:
    host: "smtp.gmail.com"
    port: 587
    user: "your_email@gmail.com"
    password: "your_app_password"
    recipient: "alerts@example.com"
  webhook:
    url: "https://hooks.slack.com/services/your/webhook/url"
