def _rolling_slope(series: pd.Series, window: int) -> pd.Series:
    """
    Causal linear-regression slope over a rolling window.

    Uses a vectorized closed-form formula for O(N) efficiency,
    avoiding the overhead of rolling().apply().

    Parameters
    ----------
    series : pd.Series
    window : int

    Returns
    -------
    pd.Series of slope values (NaN for the first window-1 bars).
    """
    # x values are just 0, 1, ..., window-1
    x = np.arange(window)
    x_sum = x.sum()
    x2_sum = (x**2).sum()
    denominator = window * x2_sum - x_sum**2

    # Vectorized rolling sums using pandas
    # Correct alignment:
    # slope = (window * Σ(x_i * y_i) - Σx * Σy) / (window * Σx² - (Σx)²)
    # where x_i = 0, 1, ..., window-1 for the window ending at t.
    # Σ(x_i * y_i) = 0*y_{t-w+1} + 1*y_{t-w+2} + ... + (w-1)*y_t

    # We can compute Σ(i * y_i) by using a rolling sum of (index_pos * y).
    # Let Y be the series. Let I be the position index 0, 1, 2, ...
    # Σ_{i=t-w+1}^t ( (i - (t-w+1)) * Y_i )
    # = Σ (i*Y_i - (t-w+1)*Y_i)
    # = Σ(i*Y_i) - (t-w+1) * ΣY_i

    i = np.arange(len(series))
    i_y = series.values * i
    sum_i_y = pd.Series(i_y, index=series.index).rolling(window).sum()
    sum_y = series.rolling(window).sum()
    t_start = i - window + 1

    sum_xy = sum_i_y - t_start * sum_y

    slope = (window * sum_xy - x_sum * sum_y) / denominator
    return slope
